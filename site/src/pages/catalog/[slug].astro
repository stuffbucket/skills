---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { ICON_PATHS } from '../../lib/icons.js';

export async function getStaticPaths() {
  const skills = await getCollection('skills');
  return skills.map(skill => {
    // Find pipeline siblings if this skill belongs to a pipeline
    let pipelineStages: typeof skills = [];
    if (skill.data.pipeline) {
      pipelineStages = skills
        .filter(s => s.data.pipeline === skill.data.pipeline)
        .sort((a, b) => (a.data.pipelineOrder ?? 99) - (b.data.pipelineOrder ?? 99));
    }
    return {
      params: { slug: skill.data.skillSlug },
      props: { skill, pipelineStages },
    };
  });
}

const { skill, pipelineStages } = Astro.props;
const { Content } = await render(skill);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const repoUrl = `https://github.com/stuffbucket/skills/tree/main/${skill.data.repoPath}`;
const iconPath = ICON_PATHS[skill.data.icon] || ICON_PATHS.package;
---

<Base title={skill.data.name} description={skill.data.description}>
  <article class="skill-page">
    <div class="skill-header">
      <a class="skill-back" href={`${base}/catalog/`}>&larr; Catalog</a>
      <div class="skill-header-top">
        <div class="skill-header-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPath} />
        </div>
        <h1>{skill.data.name}</h1>
      </div>
      <p class="skill-description">{skill.data.description}</p>

      <div class="skill-meta">
        {skill.data.license && (
          <span class="meta-badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {skill.data.license}
          </span>
        )}
        {skill.data.hasScripts && (
          <span class="meta-badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            {skill.data.scriptCount} script{skill.data.scriptCount !== 1 ? 's' : ''}
          </span>
        )}
        {skill.data.hasReferences && (
          <span class="meta-badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
            references
          </span>
        )}
        {skill.data.hasAssets && (
          <span class="meta-badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            assets
          </span>
        )}
        {skill.data.allowedTools.length > 0 && (
          <span class="meta-badge" title={skill.data.allowedTools.join(', ')}>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
            {skill.data.allowedTools.length} tool{skill.data.allowedTools.length !== 1 ? 's' : ''}
          </span>
        )}
        <a class="meta-badge meta-link" href={repoUrl} target="_blank" rel="noopener">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
          Source
        </a>
      </div>
    </div>

    {pipelineStages.length > 1 && (
      <nav class="pipeline-nav" aria-label="Pipeline stages">
        <span class="pipeline-nav-label">Pipeline</span>
        <div class="pipeline-stages">
          {pipelineStages.map((stage, i) => (
            <>
              {i > 0 && <span class="pipeline-arrow" aria-hidden="true">→</span>}
              {stage.data.skillSlug === skill.data.skillSlug ? (
                <span class="pipeline-stage pipeline-stage--current" aria-current="step">
                  {stage.data.pipelineStage ?? stage.data.name}
                </span>
              ) : (
                <a class="pipeline-stage" href={`${base}/catalog/${stage.data.skillSlug}/`}>
                  {stage.data.pipelineStage ?? stage.data.name}
                </a>
              )}
            </>
          ))}
        </div>
      </nav>
    )}

    <div class="skill-content">
      <Content />
    </div>

    {skill.data.allowedTools.length > 0 && (
      <aside class="skill-sidebar">
        <h4>Allowed tools</h4>
        <ul>
          {skill.data.allowedTools.map(tool => (
            <li><code>{tool}</code></li>
          ))}
        </ul>
      </aside>
    )}
  </article>
</Base>
