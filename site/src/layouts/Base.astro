---
import '../styles/global.css';
import '@fontsource-variable/inter';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Stuffbucket Skills</title>
  {description && <meta name="description" content={description} />}
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <ClientRouter />
</head>
<body>

<div class="hero-gradient"><span class="blob"></span></div>

<nav class="site-nav" transition:persist>
  <div class="site-nav-inner">
    <a class="site-nav-brand" href={`${base}/`}>
      <span class="text-gradient"><b>Stuffbucket Skills</b></span>
    </a>
    <div class="site-nav-search">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input
        type="text"
        class="nav-search-input"
        id="skill-search"
        placeholder="Search skills..."
        autocomplete="off"
      />
    </div>
    <div class="site-nav-links">
      <a href={`${base}/catalog/`}>Catalog</a>
      <a href={`${base}/create/`}>Create</a>
      <a href={`${base}/docs/`}>Docs</a>
      <a href={`${base}/about/`}>About</a>
      <a href={`${base}/philosophy/`}>Philosophy</a>
      <a href="https://github.com/stuffbucket/skills">GitHub</a>
    </div>
  </div>
</nav>

<main>
  <slot />
</main>

<footer class="footer" transition:persist>
  <a href="https://github.com/stuffbucket/skills">Stuffbucket Skills</a> · MIT License
</footer>

<script>
  const nav = document.querySelector('.site-nav');
  if (nav) {
    const update = () => {
      if (window.scrollY > 2) nav.setAttribute('data-scrolled', '');
      else nav.removeAttribute('data-scrolled');
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>

<script>
  // ── Global search coordinator ──────────────────────────────
  // Runs on every page. Bridges the persisted nav search input
  // to the catalog grid (if present) via a CustomEvent.

  let restoreTimer: ReturnType<typeof setTimeout> | null = null;

  function dispatchSearch(query: string) {
    document.dispatchEvent(new CustomEvent('skill-search:query', { detail: { query } }));
  }

  function updateHero(query: string, inputFocused: boolean) {
    const hero = document.getElementById('landing-hero');
    if (!hero) return;

    if (restoreTimer) { clearTimeout(restoreTimer); restoreTimer = null; }

    if (query) {
      hero.classList.add('hero--collapsed');
    } else if (!inputFocused) {
      restoreTimer = setTimeout(() => {
        hero.classList.remove('hero--collapsed');
      }, 1500);
    }
  }

  function handleInput(e: Event) {
    const input = e.target as HTMLInputElement;
    const query = input.value.trim();
    dispatchSearch(query);
    updateHero(query, true);
  }

  function handleFocus() {
    if (restoreTimer) { clearTimeout(restoreTimer); restoreTimer = null; }
  }

  function handleBlur() {
    const input = document.getElementById('skill-search') as HTMLInputElement;
    if (!input?.value.trim()) {
      updateHero('', false);
    }
  }

  document.addEventListener('astro:page-load', () => {
    const input = document.getElementById('skill-search') as HTMLInputElement;
    const searchWrap = document.querySelector('.site-nav-search') as HTMLElement;
    const grid = document.getElementById('catalog-grid');

    // Clear search on navigation
    if (input) input.value = '';

    // Show search only on pages with the catalog grid
    if (searchWrap) {
      searchWrap.style.display = grid ? '' : 'none';
    }

    if (!input || !grid) return;

    // Bind listeners once (nav is persisted across transitions)
    if (!input.dataset.globalBound) {
      input.dataset.globalBound = 'true';
      input.addEventListener('input', handleInput);
      input.addEventListener('focus', handleFocus);
      input.addEventListener('blur', handleBlur);
    }

    // Dispatch initial state
    requestAnimationFrame(() => {
      const query = input.value.trim();
      if (query) {
        dispatchSearch(query);
        updateHero(query, document.activeElement === input);
      } else {
        const hero = document.getElementById('landing-hero');
        if (hero) hero.classList.remove('hero--collapsed');
        dispatchSearch('');
      }
    });
  });
</script>

</body>
</html>
