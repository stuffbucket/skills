{
  "config": {
    "default": true,
    "MD013": {
      "line_length": 200,
      "heading_line_length": 120,
      "tables": false
    },
    "MD024": {
      "siblings_only": true
    },
    "MD033": {
      "allowed_elements": ["br"]
    },
    "MD041": false
  },
  "ignores": [
    "node_modules/**",
    "site/node_modules/**",
    "THIRD_PARTY_NOTICES.md"
  ]
}
