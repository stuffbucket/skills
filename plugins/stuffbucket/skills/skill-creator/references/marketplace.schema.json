{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Marketplace Plugin Manifest",
  "type": "object",
  "required": ["name", "description", "owner", "plugins"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "owner": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string" }
      },
      "additionalProperties": false
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source", "description"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "version": { "type": "string" },
          "author": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "email": { "type": "string" }
            },
            "additionalProperties": false
          },
          "source": { "type": "string", "pattern": "^\\./" },
          "category": { "type": "string" },
          "strict": { "type": "boolean" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "homepage": { "type": "string" },
          "skills": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "lspServers": { "type": "object" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
