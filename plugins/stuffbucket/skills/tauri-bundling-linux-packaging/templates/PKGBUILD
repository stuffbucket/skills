# Maintainer: Your Name <you@example.com>
pkgname=myapp-bin
_pkgname=myapp
pkgver=1.0.0
pkgrel=1
pkgdesc="One-line description of your Tauri app"
arch=('x86_64' 'aarch64')
url="https://github.com/example/myapp"
license=('MIT')
depends=(
    'cairo'
    'desktop-file-utils'
    'gdk-pixbuf2'
    'glib2'
    'gtk3'
    'hicolor-icon-theme'
    'libsoup3'
    'pango'
    'webkit2gtk-4.1'
)
options=('!strip' '!emptydirs')
source_x86_64=("${url}/releases/download/v${pkgver}/${_pkgname}_${pkgver}_amd64.deb")
source_aarch64=("${url}/releases/download/v${pkgver}/${_pkgname}_${pkgver}_arm64.deb")
sha256sums_x86_64=('SKIP')   # fill in real sha after first build
sha256sums_aarch64=('SKIP')

package() {
    # Unpack the .deb
    bsdtar -xf "data.tar.gz" -C "${pkgdir}"

    # Some Tauri .debs ship a /usr/share/doc/<name>/changelog.gz that
    # conflicts with Arch's expectations — keep, but don't fail if missing.
    [[ -f "${pkgdir}/usr/share/doc/${_pkgname}/changelog.gz" ]] && true
}

# After editing this PKGBUILD:
#   updpkgsums                         # fill sha256sums from sources
#   makepkg --printsrcinfo > .SRCINFO  # regenerate metadata for AUR
#   makepkg -si                        # test the build + install locally
