# GitHub Copilot CLI runner for the @stuffbucket/skills MCP server (Alpine, musl).
#
# Build context: tests/runners/ (run.sh drops the freshly packed pkg.tgz here).
# Built with network; intended to be RUN with `--network none` so the smoke
# test provably needs no model subscription or npm registry access.
#
# Alpine notes:
#   - The Copilot CLI requires Node 24+, hence node:24-alpine.
#   - It ships a musl native binary (copilot-linuxmusl-arm64); libstdc++/libgcc
#     are its runtime deps.
#   - That native *agent* binary currently segfaults on startup under musl
#     (upstream bug; prints a benign "terminated by signal SIGSEGV" line on
#     stderr). The MCP config commands this runner uses — `mcp add/list/get` —
#     fall back to JS and work correctly, and the actual skill serving is proven
#     by the CLI-agnostic mcp-smoke.mjs (plain node, unaffected).
FROM node:24-alpine

RUN apk add --no-cache bash ca-certificates libstdc++ libgcc

# Big, stable layer: the Copilot CLI. Pinned; npm cache cleaned to stay small.
RUN npm install -g @github/copilot@1.0.56 && npm cache clean --force

# Per-run layer: local install of the build under test, so the documented
# `npx -y @stuffbucket/skills` resolves offline from /work.
WORKDIR /work
COPY pkg.tgz /tmp/pkg.tgz
RUN npm init -y >/dev/null 2>&1 \
  && npm install /tmp/pkg.tgz \
  && npm cache clean --force \
  && rm -f /tmp/pkg.tgz

# Test harness.
COPY mcp-smoke.mjs /opt/runner/mcp-smoke.mjs
COPY copilot-runner.sh /opt/runner/copilot-runner.sh

ENV CI=1

CMD ["bash", "/opt/runner/copilot-runner.sh"]
