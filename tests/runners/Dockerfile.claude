# Claude Code CLI runner for the @stuffbucket/skills MCP server (Alpine, musl).
#
# Build context: tests/runners/ (run.sh drops the freshly packed pkg.tgz here).
# Built with network; intended to be RUN with `--network none` so the smoke
# test provably needs no model subscription or npm registry access.
#
# Alpine note: the Claude Code CLI runs cleanly on musl. node:24-alpine keeps
# the image small; only bash (runner script) and ca-certificates are added.
FROM node:24-alpine

RUN apk add --no-cache bash ca-certificates

# Big, stable layer: the Claude Code CLI. Pinned; npm cache cleaned to stay small.
RUN npm install -g @anthropic-ai/claude-code@2.1.158 && npm cache clean --force

# Per-run layer: local install of the build under test, so the documented
# `npx -y @stuffbucket/skills` resolves offline from /work.
WORKDIR /work
COPY pkg.tgz /tmp/pkg.tgz
RUN npm init -y >/dev/null 2>&1 \
  && npm install /tmp/pkg.tgz \
  && npm cache clean --force \
  && rm -f /tmp/pkg.tgz

# Test harness.
COPY mcp-smoke.mjs /opt/runner/mcp-smoke.mjs
COPY claude-runner.sh /opt/runner/claude-runner.sh

# Keep telemetry/auto-update from reaching out (also blocked by --network none).
ENV CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 \
    DISABLE_AUTOUPDATER=1 \
    CI=1

CMD ["bash", "/opt/runner/claude-runner.sh"]
